    "product_title": "a.product-item-link",
    "product_price": "span.price",
    "product_url": "a.product-item-link",
    "product_image": "img.product-image-photo",
    "stock_status": "div.stock"
  },
  "authentication": {
    "required": true,
    "login_url": "https://www.harrisonsdirect.co.uk/customer/account/login/",

{
  "supplier_id": "clearance-king.co.uk",
  "supplier_name": "Clearance King UK",
  "base_url": "https://www.clearance-king.co.uk/",
  "api_config": {
    "base_url": "https://www.clearance-king.co.uk"
  },
  "scraping_config": {
    "enabled": true,
    "rate_limit": {
      "requests_per_minute": 30,
      "delay_between_requests": 2.0
    }
  },
  "authentication": {
    "login_url": "https://www.clearance-king.co.uk/customer/account/login/",
    "login_selectors": {
      "email_field": "input#email",
      "password_field": "input#pass",
      "login_button": "button#send2.action.login.primary"
    },
    "authentication_check_selectors": [
      ".customer-welcome",
      ".logged-in",
      ".customer-name"
    ]
  },
  "field_mappings": {
    "product_item": [
      "li.item.product.product-item",
      ".product-item",
      "div.product-item-details"
    ],
    "title": [
      ".product-item-name a",
      "a.product-item-link",
      ".product-item-link",
      "h4.product-name a"
    ],
    "price": [
      ".price-box .price",
      "span.price",
      ".price-wrapper .price.discount",
      ".price-wrapper .price",
      "meta[property=\"product:price:amount\"]",
      "[data-price-amount]",
      "meta[itemprop='price']",
      ".regular-price .price",
      ".price-final_price .price",
      ".product-item .price"
    ],
    "price_login_required": [
      "a.btn.customer-login-link.login-btn",
      ".product-item a.btn.customer-login-link.login-btn"
    ],
    "url": [
      "a.product-item-link",
      ".product-item-link",
      ".product-name a"
    ],
    "image": [
      "img.product-image-photo",
      ".product-item img.product-image-photo",
      ".product-item .product-image-photo"
    ],
    "ean": [
      "span.ck-b-code-value",
      "dt:contains('Product Barcode') + dd",
      "dt:contains('EAN') + dd",
      "dt:contains('Barcode') + dd",
      "*:contains('Product Barcode/ASIN/EAN:') + *",
      "[data-ean]",
      "script[type=\"application/ld+json\"]",
      "meta[itemprop=\"gtin13\"]",
      "meta[property=\"product:ean\"]"
    ],
    "barcode": [
      "span.ck-b-code-value",
      "dt:contains('Product Barcode') + dd",
      "dt:contains('Barcode') + dd",
      "*:contains('Product Barcode/ASIN/EAN:') + *",
      "[data-barcode]",
      "script[type=\"application/ld+json\"]",
      "meta[itemprop=\"gtin13\"]"
    ],
    "product_code": [
      "[data-product-sku]",
      ".product-item .sku",
      "meta[itemprop=\"sku\"]"
    ],
    "sku": [
      "[data-product-sku]",
      ".product-item .sku"
    ],
    "out_of_stock": [
      "div.stock.unavailable",
      ".stock.unavailable span",
      ".stock.unavailable",
      "span:contains('Out of stock')",
      "span:contains('DISCONTINUED')",
      ".product-info-stock-sku .stock.unavailable"
    ],
    "stock_status": [
      ".stock.available",
      ".stock.unavailable",
      ".product-info-stock-sku .stock"
    ],
    "product_detail_title": [
      ".page-title .base",
      ".product-info-main .page-title span",
      "h1.page-title"
    ],
    "product_detail_price": [
      ".price-wrapper .price",
      ".product-info-price .price-box .price",
      ".price-final_price .price"
    ]
  },
  "navigation_configuration": {
    "navigation_strategy": "predefined_categories",
    "homepage_products_unreliable": true,
    "use_predefined_categories": true,
    "predefined_categories": []
  },
  "pagination": {
    "pattern": "https://www.clearance-king.co.uk/catalogsearch/result/index/?q={query}&p={page}",
    "use_url_navigation": true,
    "next_button_selector": [
      "a.action.next",
      ".pagination .next a",
      "a[rel='next']"
    ],
    "next_button_javascript": "const nextButton = document.querySelector('a.action.next'); if (nextButton) { nextButton.click(); } else { console.error('Next button not found'); }"
  },
  "page_limiter": {
    "selector": "a[data-role=\"limiter\"][data-value=\"60\"]",
    "value": "60",
    "note": "Sets products per page to 60 - optional optimization"
  },
  "auto_discovered": false,
  "discovery_timestamp": "2025-09-18T04:05:00.000000",
  "success": true,
  "use_ai_category_progression": false
}
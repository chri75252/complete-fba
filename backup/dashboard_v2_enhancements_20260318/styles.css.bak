/* ===================================================================
   FBA Analytics Engine — MD3 Dark Palette
   Built with Anthropic Frontend Skills Pack Guidelines
   =================================================================== */

:root {
    --bg-body: #131314;
    --bg-surface: #1c1b1c;
    --bg-surface-raised: #201f20;
    --bg-surface-hover: #2a2a2b;

    --border-subtle: rgba(70, 69, 84, 0.15);
    --border-default: rgba(70, 69, 84, 0.3);
    --border-accent: #c0c1ff;

    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Manrope', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;

    --text-primary: #e5e2e3;
    --text-secondary: #c7c4d7;
    --text-muted: #908fa0;
    --text-inverse: #313031;

    --accent: #c0c1ff;
    --accent-light: #e1e0ff;
    --accent-glow: rgba(192, 193, 255, 0.25);

    --success: #4edea3;
    --success-bg: rgba(78, 222, 163, 0.1);
    --warning: #ffb95f;
    --warning-bg: rgba(255, 185, 95, 0.1);
    --error: #ffb4ab;
    --error-bg: rgba(255, 180, 171, 0.1);
    --info: #c0c1ff;

    --chart-1: #c0c1ff;
    --chart-2: #4edea3;
    --chart-3: #ffb95f;
    --chart-4: #ffb4ab;
    --chart-5: #8083ff;
    --chart-6: #00a572;

    --radius-sm: 0.125rem;
    --radius-md: 0.25rem;
    --radius-lg: 0.5rem;

    --sidebar-w: 280px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 14px; scroll-behavior: smooth; }

body {
    font-family: var(--font-body);
    background-color: var(--bg-body);
    color: var(--text-primary);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    selection-background-color: var(--accent);
    selection-color: var(--text-inverse);
}

::selection {
    background: var(--accent);
    color: var(--text-inverse);
}

/* Custom Scrollbar from pro-max */
.custom-scrollbar::-webkit-scrollbar,
::-webkit-scrollbar { width: 4px; }
.custom-scrollbar::-webkit-scrollbar-track,
::-webkit-scrollbar-track { background: #131314; }
.custom-scrollbar::-webkit-scrollbar-thumb,
::-webkit-scrollbar-thumb { background: #353436; border-radius: 2px; }

/* Glass Overlay */
.glass-panel {
    background: rgba(53, 52, 54, 0.6);
    backdrop-filter: blur(20px);
}

.app-container { display: flex; min-height: 100vh; }

/* ===== UTILS & ANIMATION ===== */
@keyframes fadeInUpStagger {
    0% { opacity: 0; transform: translateY(15px); }
    100% { opacity: 1; transform: translateY(0); }
}

.stagger-1 { animation: fadeInUpStagger 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both; }
.stagger-2 { animation: fadeInUpStagger 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both; }
.stagger-3 { animation: fadeInUpStagger 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both; }
.stagger-4 { animation: fadeInUpStagger 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both; }
.stagger-5 { animation: fadeInUpStagger 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both; }

/* ===== SIDEBAR ===== */
.sidebar {
    width: var(--sidebar-w);
    background: var(--bg-body);
    border-right: 1px solid var(--border-default);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100;
    overflow-y: auto;
}

.logo {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 32px 24px 28px;
    border-bottom: 1px solid var(--border-subtle);
}

.logo-mark {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #c0c1ff 0%, #8083ff 100%);
    color: var(--text-inverse);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: -1px;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
}

.logo-text h2 { 
    font-family: var(--font-display);
    font-size: 1.1rem; 
    font-weight: 800; 
    color: #fff; 
    line-height: 1.1; 
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.logo-sub { 
    font-family: var(--font-mono);
    font-size: 0.65rem; 
    color: var(--text-muted); 
    text-transform: uppercase; 
    letter-spacing: 1px; 
    margin-top: 4px;
    display: block;
}

.nav-links { display: flex; flex-direction: column; gap: 4px; padding: 24px 16px; flex-grow: 1; }

.nav-item {
    padding: 12px 16px;
    text-decoration: none;
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid transparent;
}

.nav-icon { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.7; }

.nav-item:hover { 
    background: var(--bg-surface-raised); 
    color: var(--text-primary); 
    transform: translateX(4px);
}

.nav-item.active {
    background: var(--bg-surface);
    color: var(--accent);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--accent);
}
.nav-item.active .nav-icon { opacity: 1; }

.sidebar-config {
    padding: 24px 20px;
    background: var(--bg-surface);
    border-top: 1px solid var(--border-default);
}

.config-header {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.config-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
}

.status-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    margin-top: 20px;
    border: 1px solid var(--border-subtle);
}

.status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
}

.status-badge.connecting { background: var(--bg-body); color: var(--warning); border-color: var(--warning-bg); }
.status-badge.connecting .status-dot { background: var(--warning); animation: pulse-dot 1s infinite; }
.status-badge.connected { background: var(--bg-body); color: var(--accent); border-color: var(--accent-glow); }
.status-badge.connected .status-dot { background: var(--accent); box-shadow: 0 0 8px var(--accent); }

@keyframes pulse-dot { 0%,100% { opacity: 1; } 50% { opacity: 0.2; } }

.sidebar-footer { margin-top: 16px; }
.sidebar-info { 
    font-family: var(--font-mono);
    font-size: 0.65rem; 
    color: var(--text-muted); 
    line-height: 1.8; 
    white-space: nowrap; 
    overflow: hidden; 
    text-overflow: ellipsis; 
}

/* ===== MAIN CONTENT ===== */
.main-content {
    margin-left: var(--sidebar-w);
    flex-grow: 1;
    padding: 40px 48px;
    min-width: 0;
}

.view { display: none; }
.view.active { display: block; }

/* Live Ticker */
.live-ticker {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-sm);
    margin-bottom: 32px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-primary);
}

.ticker-dot {
    width: 10px;
    height: 10px;
    background: var(--success);
    animation: flash-dot 1.5s infinite steps(2);
    flex-shrink: 0;
}
@keyframes flash-dot { 0% { opacity: 1; } 100% { opacity: 0; } }

.view-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-subtle);
}

.view-header h1 { 
    font-family: var(--font-display);
    font-size: 2.2rem; 
    font-weight: 800; 
    color: #fff; 
    letter-spacing: -0.5px;
}
.view-subtitle { 
    font-family: var(--font-mono);
    font-size: 0.8rem; 
    color: var(--text-muted); 
    margin-top: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.btn-outline {
    background: transparent;
    border: 1px solid var(--border-default);
    color: var(--text-primary);
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-outline:hover { 
    background: var(--text-primary); 
    color: var(--text-inverse); 
}

/* ===== CARDS ===== */
.card {
    background: #1c1b1c;
    border: 1px solid rgba(70, 69, 84, 0.1);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    outline: 1px solid rgba(70, 69, 84, 0.15);
}

.card::before { display: none; }

.card:hover {
    outline-color: rgba(192, 193, 255, 0.25);
    background: #201f20;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 24px;
    border-bottom: 1px solid rgba(70, 69, 84, 0.1);
    background: transparent;
}

.card-header h3 { 
    font-family: var(--font-display);
    font-size: 0.85rem; 
    font-weight: 800; 
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #fff; 
}

.card-body { padding: 24px; }

/* ===== METRIC CARDS ===== */
.metrics-grid-6 {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    margin-bottom: 24px;
}

.metric-card { 
    padding: 24px 20px; 
    display: flex;
    flex-direction: column;
}

.metric-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    margin-bottom: 12px;
}

.metric-value {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -1px;
}

.metric-sub {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: auto;
}

.accent-val { color: var(--accent); }

.hero-card {
    background: linear-gradient(135deg, #c0c1ff 0%, #8083ff 100%);
    border-color: var(--accent);
    color: #1000a9;
}
.hero-card::before { display: none; }
.hero-card .metric-label { color: rgba(0,0,0,0.6); }
.hero-card .metric-sub { color: rgba(0,0,0,0.8); font-weight: 600; }
.hero-card .hero-value {
    color: #000;
    font-size: 2.2rem;
}
.hero-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px var(--accent-glow);
}

/* ===== GRIDS ===== */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
.grid-1 { display: grid; grid-template-columns: 1fr; gap: 20px; margin-bottom: 20px; }

.section-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: #fff;
    margin: 48px 0 20px;
    display: flex;
    align-items: center;
    gap: 12px;
}
.section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-default);
}

/* ===== DETAIL GRID (Health/Matching Panels) ===== */
.detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
}

.detail-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px dashed var(--border-subtle);
}
.detail-item:last-child { border-bottom: none; }
.detail-item.full-width { grid-column: 1 / -1; }

.detail-label { 
    font-family: var(--font-mono);
    font-size: 0.72rem; 
    color: var(--text-secondary); 
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.detail-value { 
    font-size: 0.95rem; 
    font-weight: 700; 
    color: var(--text-primary); 
    text-align: right; 
}

.detail-item:nth-child(odd) { padding-right: 24px; border-right: 1px dashed var(--border-subtle); }
.detail-item:nth-child(even) { padding-left: 24px; }
.detail-item.full-width { padding-right: 0; padding-left: 0; border-right: none; }

.badge {
    background: var(--text-primary);
    color: var(--text-inverse);
    padding: 4px 10px;
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
}

.success-text { color: var(--success); }
.warn-text { color: var(--warning); }
.mono-text { 
    font-family: var(--font-mono); 
    font-size: 0.8rem; 
    max-width: 340px; 
    overflow: hidden; 
    text-overflow: ellipsis; 
    white-space: nowrap; 
    color: var(--accent);
}

/* ===== CONFIDENCE DISTRIBUTION ===== */
.conf-distribution {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--border-default);
}

.conf-header {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    font-weight: 700;
    margin-bottom: 14px;
}

.conf-bars { display: flex; gap: 8px; flex-wrap: wrap; }

.conf-chip {
    display: flex;
    align-items: center;
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    overflow: hidden;
}

.conf-chip-label { 
    padding: 6px 10px;
    color: var(--text-secondary); 
    border-right: 1px solid var(--border-subtle);
}
.conf-chip-val {
    padding: 6px 10px;
    font-weight: 700;
    color: var(--accent);
    background: rgba(192, 193, 255, 0.08);
}
.conf-empty { color: var(--text-muted); font-size: 0.8rem; font-style: italic; }

/* ===== CHARTS ===== */
.chart-card { min-height: 0; }
.chart-wrap { padding: 20px 24px; height: 300px; }
.chart-wrap-short { height: 240px; }

/* ===== LOGS ===== */
.log-trace {
    padding: 24px;
    max-height: 360px;
    overflow-y: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.7;
    color: #a1a1aa;
    background: var(--bg-body);
}

.log-filename {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    background: rgba(192, 193, 255, 0.1);
    padding: 4px 8px;
    border-radius: 2px;
}
.log-line-muted { color: var(--text-muted); font-style: italic; }

/* ===== FORM / INPUT ===== */
.glass-input {
    width: 100%;
    background: var(--bg-body);
    border: 1px solid var(--border-default);
    color: var(--text-primary);
    padding: 12px 14px;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
    outline: none;
    transition: all 0.2s;
}

.glass-input:focus {
    border-color: var(--accent);
    background: rgba(192, 193, 255, 0.02);
}
.glass-input:disabled { opacity: 0.5; cursor: not-allowed; }

.input-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
.input-group label { 
    font-family: var(--font-mono);
    font-size: 0.7rem; 
    color: var(--text-secondary); 
    font-weight: 700; 
    text-transform: uppercase; 
    letter-spacing: 1px; 
}

.form-row { display: flex; gap: 20px; }
.form-row .input-group { flex: 1; }

.btn-primary {
    background: linear-gradient(135deg, #c0c1ff 0%, #8083ff 100%);
    color: #1000a9;
    border: none;
    padding: 10px 16px; /* asymmetric padding py-2.5 px-4 */
    border-radius: var(--radius-sm);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: transform 150ms ease, box-shadow 150ms ease;
}

.btn-primary:hover { 
    transform: scale(0.98);
}
.btn-primary:active {
    transform: scale(0.95);
}
.btn-primary:disabled { opacity: 0.5; background: var(--text-muted); cursor: not-allowed; transform: none; box-shadow: none; }

.empty-state { 
    color: var(--text-muted); 
    font-family: var(--font-mono);
    font-size: 0.8rem; 
    text-align: center; 
    padding: 48px 0; 
}

/* ===== CHAT (OPERATOR TTY) ===== */
.chat-container {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 200px);
}

.chat-history {
    flex-grow: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.chat-message {
    display: flex;
    gap: 16px;
    max-width: 85%;
    animation: fadeInUpStagger 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.chat-message.assistant { align-self: flex-start; }
.chat-message.user { align-self: flex-end; flex-direction: row-reverse; }

.avatar {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-default);
}
.chat-message.assistant .avatar { background: var(--text-primary); color: var(--text-inverse); }

.msg-bubble {
    background: var(--bg-surface);
    padding: 16px 20px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-default);
    line-height: 1.6;
    font-size: 0.95rem;
}

.chat-message.user .msg-bubble {
    background: rgba(255,255,255,0.03);
    border-color: var(--text-muted);
}

.chat-input-area {
    display: flex;
    gap: 12px;
    padding: 20px 24px;
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-body);
}

.chat-input-area input { 
    flex-grow: 1; 
    font-family: var(--font-mono); /* TTY feel */
}

/* Thinking Animation */
.thinking-bubble { color: var(--text-muted); font-family: var(--font-mono); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px;}
.thinking-dots span { animation: blink 1.4s infinite both; }
.thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
.thinking-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink { 0%,100% { opacity:0.2; } 20% { opacity:1; color: var(--accent); } }

/* Agent Trace */
.trace-container { 
    margin-bottom: 16px; 
    border-left: 2px solid var(--accent); 
    padding-left: 16px; 
}
.trace-step { margin-bottom: 12px; }
.trace-label { 
    font-family: var(--font-mono);
    color: var(--accent); 
    font-size: 0.7rem; 
    font-weight: 700; 
    letter-spacing: 1px; 
    text-transform: uppercase;
}
.trace-explanation { color: var(--text-secondary); margin-top: 4px; font-size: 0.85rem; }
.trace-result-details { margin-top: 8px; }
.trace-result-details summary { 
    cursor: pointer; 
    color: var(--text-muted); 
    font-family: var(--font-mono);
    font-size: 0.75rem; 
    text-transform: uppercase;
}
.trace-result-details summary:hover { color: var(--text-primary); }
.trace-result { 
    background: var(--bg-body); 
    padding: 12px; 
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm); 
    font-family: var(--font-mono); 
    font-size: 0.75rem; 
    color: var(--text-secondary); 
    max-height: 260px; 
    overflow: auto; 
    white-space: pre-wrap; 
    word-break: break-word; 
    margin-top: 8px; 
}

/* Approval */
.approval-card { 
    background: var(--warning-bg); 
    border: 1px solid var(--warning); 
    border-radius: var(--radius-sm); 
    padding: 20px; 
    margin-top: 12px; 
}
.approval-card h4 { 
    color: var(--warning); 
    margin-bottom: 12px; 
    font-family: var(--font-display);
    font-size: 1rem; 
    text-transform: uppercase;
    letter-spacing: 1px;
}
.approval-tool-name { 
    font-family: var(--font-mono); 
    font-size: 1.1rem; 
    font-weight: 700; 
    color: #fff; 
    margin-bottom: 8px; 
}
.approval-explanation { color: var(--text-primary); font-size: 0.95rem; margin-bottom: 12px; }
.approval-params { 
    background: rgba(0,0,0,0.5); 
    padding: 12px; 
    border: 1px solid rgba(255,184,0,0.3);
    border-radius: var(--radius-sm); 
    font-family: var(--font-mono); 
    font-size: 0.75rem; 
    color: var(--warning); 
    max-height: 180px; 
    overflow: auto; 
    white-space: pre-wrap; 
    margin-bottom: 16px; 
}
.approval-actions { display: flex; gap: 12px; }
.btn-approve { 
    background: var(--success); 
    border: none; 
    color: #000; 
    padding: 10px 20px; 
    border-radius: var(--radius-sm); 
    font-weight: 800; 
    cursor: pointer; 
    font-size: 0.85rem; 
    text-transform: uppercase;
    font-family: var(--font-display); 
}
.btn-reject { 
    background: transparent; 
    border: 1px solid var(--error); 
    color: var(--error); 
    padding: 10px 20px; 
    border-radius: var(--radius-sm); 
    font-weight: 800; 
    cursor: pointer; 
    font-size: 0.85rem; 
    text-transform: uppercase;
    font-family: var(--font-display); 
}
.btn-approve:hover { background: #00cc52; }
.btn-reject:hover { background: var(--error-bg); }
.btn-approve:disabled, .btn-reject:disabled { opacity: 0.4; cursor: not-allowed; }

.error-block { 
    background: var(--error-bg); 
    border: 1px solid var(--error); 
    padding: 12px 16px; 
    border-radius: var(--radius-sm); 
    color: #ffb3b3; 
    font-size: 0.9rem; 
}
.success-block { 
    background: var(--success-bg); 
    border: 1px solid var(--success); 
    padding: 12px 16px; 
    border-radius: var(--radius-sm); 
    color: #b3ffcc; 
    font-size: 0.9rem; 
}
.final-answer { margin-top: 8px; white-space: pre-wrap; line-height: 1.7; }

/* ===== DATA TABLES ===== */
.velocity-badge {
    margin-left: auto;
    background: rgba(192, 193, 255, 0.1);
    color: var(--accent);
    padding: 4px 8px;
    border: 1px solid var(--accent);
    border-radius: var(--radius-sm);
    font-size: 0.7rem;
    font-family: var(--font-mono);
}

.table-card { min-height: 280px; }
.table-wrap { overflow-x: auto; padding: 0 24px 24px; }

.data-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-align: left;
}

.data-table th {
    font-family: var(--font-display);
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-default);
    padding: 12px 8px;
    letter-spacing: 1px;
}

.data-table td {
    padding: 14px 8px;
    border-bottom: 1px dashed var(--border-subtle);
    color: var(--text-secondary);
    white-space: nowrap;
}

.data-table tbody tr:hover td {
    color: var(--text-primary);
    background: rgba(255,255,255,0.02);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1300px) {
    .metrics-grid-6 { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 900px) {
    .sidebar { width: 240px; }
    .main-content { margin-left: 240px; padding: 24px; }
    .metrics-grid-6 { grid-template-columns: repeat(2, 1fr); }
    .grid-2 { grid-template-columns: 1fr; }
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--bg-body); }
::-webkit-scrollbar-thumb { background: var(--border-default); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }
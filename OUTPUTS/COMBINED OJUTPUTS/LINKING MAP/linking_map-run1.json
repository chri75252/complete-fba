\\n 1057 |                         if await sponsored_badge_locator.count() > 0:\\r\\n 1058 |                             is_sponsored = True\\r\\n 1059 |                             sponsor_detection_reason = \\\"visible 'Sponsored' text badge\\\"\\r\\n 1060 |                     except Exception as e_badge:\\r\\n 1061 |                         log.debug(f\\\"Error checking sponsored badge for ASIN {asin}: {e_badge}\\\")\\r\\n 1062 | \\r\\n 1063 |                     # Check 2: Aria-label on the element or a significant child\\r\\n 1064 |                     if not is_sponsored:\\r\\n 1065 |                         try:\\r\\n 1066 |                             if (\\r\\n 1067 |                                 await element.locator('[aria-label=\\\"Sponsored\\\"]:visible').count()\\r\\n 1068 |                                 > 0\\r\\n 1069 |                             ):\\r\\n 1070 |                                 is_sponsored = True\\r\\n 1071 |                                 sponsor_detection_reason = \\\"aria-label='Sponsored'\\\"\\r\\n 1072 |                         except Exception as e_aria:\\r\\n 1073 |                             log.debug(f\\\"Error checking aria-label for ASIN {asin}: {e_aria}\\\")\\r\\n 1074 | \\r\\n 1075 |                     # Check 3: Data attributes on the element itself (tile)\\r\\n 1076 |                     if not is_sponsored:\\r\\n 1077 |                         try:\\r\\n 1078 |                             is_sponsored = await element.evaluate(\\r\\n 1079 |                                 \\\"\\\"\\\"el => {\\r\\n 1080 |                                 if (el.getAttribute('data-component-type') === 'sp-sponsored-result') return true;\\r\\n 1081 |                                 if (el.getAttribute('data-ad-marker') === 'true') return true;\\r\\n 1082 |                                 if (el.querySelector('[data-component-type=\\\"sp-sponsored-result\\\"]')) return true;\\r\\n 1083 |                                 if (el.quer
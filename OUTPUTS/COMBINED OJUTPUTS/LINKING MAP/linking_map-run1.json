n 1889 |     def _authoritative_total_categories(self) -> int:\\r\\n 1890 |         \\\"\\\"\\\"Return authoritative category count from predefined list.\\\"\\\"\\\"\\r\\n 1891 |         try:\\r\\n 1892 |             categories = self._get_predefined_categories(self.supplier_name) or []\\r\\n 1893 |         except Exception:\\r\\n 1894 |             categories = []\\r\\n 1895 |         return len(categories)\\r\\n 1896 | \\r\\n 1897 |     async def run(self):\\r\\n 1898 |         \\\"\\\"\\\"Main execution loop for the workflow.\\\"\\\"\\\"\\r\\n 1899 |         profitable_results: List[Dict[str, Any]] = []\\r\\n 1900 |         session_id = f\\\"{self.supplier_name}_{datetime.now().strftime('%Y%m%d_%H%M%S')}\\\"\\r\\n 1901 |         self.log.info(f\\\"--- Starting Passive Extraction Workflow for: {self.supplier_name} ---\\\")\\r\\n 1902 |         self.log.info(f\\\"Session ID: {session_id}\\\")\\r\\n 1903 | \\r\\n 1904 |         # Resolve categories and compute config hash\\r\\n 1905 |         category_urls = self._get_predefined_categories(self.supplier_name) or []\\r\\n 1906 |         cfg_hash = self.state_manager.compute_supplier_config_hash(category_urls)\\r\\n 1907 | \\r\\n 1908 |         # Freeze total categories and mark frozen BEFORE any resume logic\\r\\n 1909 |         self.state_manager.set_total_categories(len(category_urls), cfg_hash)\\r\\n 1910 |         self.state_manager.save_state_atomic()\\r\\n 1911 |         self.log.info(f\\\"🔒 FROZEN TOTAL CATEGORIES set to {len(category_urls)} (hash={cfg_hash[:8]})\\\")\\r\\n 1912 |         if hasattr(self.state_manager, \\\"mark_frozen_totals_committed\\\"):\\r\\n 1913 |             self.state_manager.mark_frozen_totals_committed()\\r\\n 1914 |         \\r\\n 1915 |         # Store config hash for lineage tracking\\r\\n 1916 |         self._cached_config_hash = cfg_hash\\r\\n 1917 | \\r\\n 1918 |         # RESUME PROOF LOG 1: LOG at startup if frozen totals are committed\\r\\n 1919 |         if hasattr(self.sta
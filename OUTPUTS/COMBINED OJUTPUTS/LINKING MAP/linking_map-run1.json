ng_map = []\\r\\n 3205 |         self.hash_optimizer.build_indexes([])\\r\\n 3206 | \\r\\n 3207 |         return []\\r\\n 3208 | \\r\\n 3209 |     def _save_linking_map(self, supplier_name: str):\\r\\n 3210 |         \\\"\\\"\\\"Save linking map to supplier-specific JSON file using Windows atomic save\\\"\\\"\\\"\\r\\n 3211 |         self.log.info(\\r\\n 3212 |             f\\\"🔍 DEBUG: _save_linking_map called with {len(self.linking_map)} entries for supplier {supplier_name}\\\"\\r\\n 3213 |         )\\r\\n 3214 | \\r\\n 3215 |         # 🚨 SENTINEL MONITORING: Track linking map size before save\\r\\n 3216 |         previous_size = 0\\r\\n 3217 |         linking_map_path = get_linking_map_path(supplier_name)\\r\\n 3218 |         # 🚨 SENTINEL MONITORING: Check for path variants\\r\\n 3219 |         self.sentinel_monitor.check_path_variants(str(linking_map_path), \\\"linking_map_access\\\")\\r\\n 3220 |         if linking_map_path.exists():\\r\\n 3221 |             try:\\r\\n 3222 |                 with open(linking_map_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\r\\n 3223 |                     existing_data = json.load(f)\\r\\n 3224 |                     previous_size = len(existing_data) if isinstance(existing_data, list) else 0\\r\\n 3225 |             except Exception as e:\\r\\n 3226 |                 self.log.warning(f\\\"⚠️ Could not read existing linking map for size comparison: {e}\\\")\\r\\n 3227 | \\r\\n 3228 |         sample_entry = self.linking_map[0] if self.linking_map else {}\\r\\n 3229 |         truncated_sample = {\\r\\n 3230 |             k: str(v)[:50] + \\\"...\\\" if len(str(v)) > 50 else v for k, v in sample_entry.items()\\r\\n 3231 |         }\\r\\n 3232 |         self.log.info(\\r\\n 3233 |             f\\\"🔍 DEBUG: linking_map type: {type(self.linking_map)}, entries: {len(self.linking_map)}, sample: {truncated_sample}\\\"\\r\\n 3234 |         )\\r\\n 3235 | \\r\\n 3236 |         if not self.linking_map:\\r\\n 3237 |             self.log.warning(\\r\\n 3238 |                 \\\"⚠️ CRITICAL: Empty linking map - nothing to save. This suggests linking map entries are not being created!\\\"\\r\\n 3239 |             )\\r\\n 3240 |             # 🚨 SENTINEL MONITORING: Alert on empty linking map\\r\\n 3241 |             self.sentinel_monitor.check_linking_map_shrinkage(0, previous_size)\\r\\n 3242 |             return\\r\\n 3243 | \\r\\n 3244 |         # Use consistent path naming with get_linking_map_path\\r\\n 3245 |         try:\\r\\n 3246 |             self.log.info(f\\\"🔍 DEBUG: Target file path: {linking_map_path}\\\")\\r\\n 3247 | \\r\\n 3248 |         except Exception as path_error:\\r\\n 3249 |             self.log.error(f\\\"❌ CRITICAL: Failed to create linking map path: {path_error}\\\")\\r\\n 3250 |             return\\r\\n 3251 | \\r\\n 3252 |         # 🔧 ATOMIC SAVE: Use Windows Save Guardian with alt-temp strategy\\r\\n 3253 |         self.log.info(\\r\\n 3254 |             f\\\"🔧 ATOMIC SAVE: Attempting to save {len(self.linking_map)} entries using atomic strategy...\\\"\\r\\n 3255 |         )\\r\\n 3256 | \\r\\n 3257 |         try:\\r\\n 3258 |             # 🚨 SENTINEL MONITORING: Track save attempt\\r\\n 3259 |             current_size = len(self.linking_map)\\r\\n 3260 |             save_success = False\\r\\n 3261 |             retry_count = 1\\r\\n 3262 | \\r\\n 3263 |             # 🛡️ Use Windows Save Guardian with anti-truncation protection\\r\\n 3264 |             success = self.save_guardian.save_json_atomic(\\r\\n 3265 |                 linking_map_path, self.linking_map, min_entries_guard=1000\\r\\n 3266 |             )\\r\\n 3267 | \\r\\n 3268 |             if success:\\r\\n 3269 |                 save_success = True\\r\\n 3270 |                 self.log.info(\\r\\n 3271 |                     f\\\"✅ Successfully saved linking map with {len(self.linking_map)} entries to {linking_map_path}\\\"\\r\\n 3272 |                 )\\r\\n 3273 | \\r\\n 3274 |                 # Verify the file was actually created and has content\\r\\n 3275 |                 if linking_map_path.exists():\\r\\n 3276 |                     file_size = linking_map_path.stat().st_size\\r\\n 3277 |                     self.log.info(\\r\\n 3278 |                         f\\\"✅ VERIFICATION: File exists at {linking_map_path} with size {file_size} bytes\\\"\\r\\n 3279 |                     )\\r\\n 3280 | \\r\\n 3281 |                     # 🚀 HASH OPTIMIZATION: Rebuild hash indexes after saving linking map\\r\\n 3282 |                     self.hash_optimizer.build_indexes(self.linking_map)\\r\\n 3283 |                     self.log.info(\\r\\n 3284 |                         f\\\"🚀 HASH INDEXES REBUILT: Updated indexes for {len(self.linking_map)} entries\\\"\\r\\n 3285 |                     )\\r\\n 3286 | \\r\\n 3287 |                     # 🚨 SENTINEL MONITORING: Check for linking map shrinkage\\r\\n 3288 |                     self.sentinel_monitor.check_linking_map_shrinkage(current_size, previous_size)\\r\\n 3289 |                     self.sentinel_monitor.track_save_retry(\\r\\n 3290 |                         \\\"windows_save_guardian\\\", True, retry_count\\r\\n 3291 |                     )\\r\\n 3292 |                 else:\\r\\n 3293 |                     self.log.error(f\\\"❌ CRITICAL: File was not created at {linking_map_path}\\\")\\r\\n 3294 |                     self.sentinel_monitor.track_save_retry(\\r\\n 3295 |                         \\\"windows_save_guardian\\\", False, retry_count\\r\\n 3296 |                     )\\r\\n 3297 |             else:\\r\\n 3298 |                 self.log.error(f\\\"❌ CRITICAL: Windows Save Guardian failed for {linking_map_path}\\\")\\r\\n 3299 |                 self.sentinel_monitor.track_save_retry(\\\"windows_save_guardian\\\", False, retry_count)\\r\\n 3300 | \\r\\n 3301 |         except Exception as e:\\r\\n 3302 |             self.log.error(f\\\"❌ CRITICAL: Error in Windows Save Guardian: {e}\\\", exc_info=True)\\r\\n 3303 |             self.sentinel_monitor.track_save_retry(\\\"windows_save_guardian\\\", False, retry_count)\\r\\n 3304 | \\r\\n 3305 |     def _classify_url(self, url: str) -> str:\\r\\n 3306 |         \\\"\\\"\\\"return 'friendly' | 'avoid' | 'neutral' based on patterns (priority order).\\\"\\\"\\\"\\r\\n 3307 |         path = url.lower()\\r\\n 3308 |         for kws in FBA_FRIENDLY_PATTERNS.values():\\r\\n 3309 |             if any(k in path for k in kws):\\r\\n 3310 |                 return \\\"friendly\\\"\\r\\n 3311 |         for kws in FBA_AVOID_PATTERNS.values():\\r\\n 3312 |             if any(k in path for k in kws):\\r\\n 3313 |                 return \\\"avoid\\\"\\r\\n 3314 |         return \\\"neutral\\\"\\r\\n 3315 | \\r\\n 3316 |     # ------------------------------------------------------------------\\r\\n 3317 |     def _save_category_manifest(\\r\\n 3318 |         self, supplier_name: str, category_url: str, urls: List[str]\\r\\n 3319 |     ) -> str:\\r\\n 3320 |         \\\"\\\"\\\"Persist the ground-truth list of product URLs for a category with atomic write using WindowsSaveGuardian.\\\"\\\"\\\"\\r\\n 3321 |         from utils.normalization import normalize_url, stable_key\\r\\n 3322 |         from utils.windows_save_guardian import WindowsSaveGuardian\\r\\n 3323 |         import re\\r\\n 3324 | \\r\\n 3325 |         # Generate category slug for consistent naming\\r\\n 3326 |         slug = re.sub(r\\\"[^a-z0-9]+\\\", \\\"-\\\", category_url.lower()).strip(\\\"-\\\")[\\r\\n 3327 |             :50\\r\\n 3328 |         ]  # Limit length for filesystem\\r\\n 3329 |         manifest_dir = Path(\\\"OUTPUTS\\\") / \\\"manifests\\\" / supplier_name\\r\\n 3330 |         manifest_dir.mkdir(parents=True, exist_ok=True)\\r\\n 3331 |         manifest_path = manifest_dir / f\\\"{slug}.json\\\"\\r\\n 3332 | \\r\\n 3333 |         # Normalize URLs for consistency\\r\\n 3334 |         normalized_urls = [normalize_url(u) for u in urls]\\r\\n 3335 | \\r\\n 3336 |         # Check for existing manifest to detect overwrites\\r\\n 3337 |         overwritten = False\\r\\n 3338 |         prev_count = None\\r\\n 3339 |         if manifest_path.exists():\\r\\n 3340 |             try:\\r\\n 3341 |                 prev_data = json.loads(manifest_path.read_text(encoding=\\\"utf-8\\\"))\\r\\n 3342 |                 prev_count = prev_data.get(\\\"count\\\", 0)\\r\\n 3343 |                 overwritten = True\\r\\n 3344 |             except Exception as e:\\r\\n 3345 |                 self.log.warning(f\\\"Could not read existing manifest for {category_url}: {e}\\\")\\r\\n 3346 | \\r\\n 3347 |         # Create manifest document with all required fields\\r\\n 3348 |         doc = {\\r\\n 3349 |             \\\"category_url\\\": category_url,\\r\\n 3350 |             \\\"scraped_at\\\": datetime.utcnow().isoformat() + \\\"Z\\\",\\r\\n 3351 |             \\\"product_urls\\\": normalized_urls,\\r\\n 3352 |             \\\"count\\\": len(normalized_urls),\\r\\n 3353 |             \\\"supplier_name\\\": supplier_name,\\r\\n 3354 |             \\\"slug\\\": slug,\\r\\n 3355 |         }\\r\\n 3356 | \\r\\n 3357 |     # _normalize_url_for_filtering no longer needed; use normalize_url everywhere in the pipeline\\r\\n 3358 | \\r\\n 3359 |         # Use WindowsSaveGuardian for atomic write\\r\\n 3360 |         guardian = WindowsSaveGuardian()\\r\\n 3361 |         success = guardian.save_json_atomic(manifest_path, doc)\\r\\n 3362 | \\r\\n 3363 |         if success:\\r\\n 3364 |             # Log manifest save with appropriate format\\r\\n 3365 |             self.log.info(f\\\"📝 MANIFEST: {len(normalized_urls)} URLs → {manifest_path}\\\")\\r\\n 3366 | \\r\\n 3367 |             # Log manifest overwrite if applicable\\r\\n 3368 |             if overwritten and prev_count is not None:\\r\\n 3369 |                 # Generate category index for logging (approximate from current processing state)\\r\\n 3370 |                 category_index = getattr(self, \\\"_current_category_index\\\", 0)\\r\\n 3371 |                 self.log.info(\\r\\n 3372 |                     f\\\"MANIFEST UPDATE[C{category_index} {slug}]: overwritten=true prev={prev_count} curr={len(normalized_urls)}\\\"\\r\\n 3373 |                 )\\r\\n 3374 | \\r\\n 3375 |                 # Log count mismatch warning if significant difference\\r\\n 3376 |                 if abs(prev_count - len(normalized_urls)) > 0:\\r\\n 3377 |                     self.log.warning(\\r\\n 3378 |                         f\\\"MANIFEST COUNT CHANGE: {category_url} changed from {prev_count} to {len(normalized_urls)} URLs\\\"\\r\\n 3379 |                     )\\r\\n 3380 | \\r\\n 3381 |             return str(manifest_path)\\r\\n 3382 |         else:\\r\\n 3383 |             self.log.error(f\\\"❌ Failed to save manifest for {category_url}\\\")\\r\\n 3384 |             raise RuntimeError(f\\\"Failed to save category manifest: {manifest_path}\\\")\\r\\n 3385 | \\r\\n 3386 |     def _set_current_category_index(self, index: int):\\r\\n 3387 |         \\\"\\\"\\\"Set current category index for manifest logging.\\\"\\\"\\\"\\r\\n 3388 |         self._current_category_index = index\\r\\n 3389 | \\r\\n 3390 |     def _generate_category_slug(self, category_url: str) -> str:\\r\\n 3391 |         \\\"\\\"\\\"Generate readable slug from category URL path\\\"\\\"\\\"\\r\\n 3392 |         try:\\r\\n 3393 |             from urllib.parse import urlparse\\r\\n 3394 |             import re\\r\\n 3395 | \\r\\n 3396 |             # Parse URL and extract path\\r\\n 3397 |             parsed = urlparse(category_url)\\r\\n 3398 |             path = parsed.path.strip(\\\"/\\\")\\r\\n 3399 | \\r\\n 3400 |             # Get the last meaningful part of the path\\r\\n 3401 |             if path:\\r\\n 3402 |                 path_parts = path.split(\\\"/\\\")\\r\\n 3403 |                 # Take the last part, or second-to-last if last is very short\\r\\n 3404 |                 if len(path_parts) > 1 and len(path_parts[-1]) < 5:\\r\\n 3405 |                     slug_base = path_parts[-2] if len(path_parts) > 1 else path_parts[-1]\\r\\n 3406 |                 else:\\r\\n 3407 |                     slug_base = path_parts[-1]\\r\\n 3408 |             else:\\r\\n 3409 |                 # Fallback to domain if no path\\r\\n 3410 |                 slug_base = parsed.netloc.replace(\\\"www.\\\", \\\"\\\").replace(\\\".\\\", \\\"-\\\")\\r\\n 3411 | \\r\\n 3412 |             # Clean up the slug\\r\\n 3413 |             slug = re.sub(r\\\"[^a-z0-9]+\\\", \\\"-\\\", slug_base.lower()).strip(\\\"-\\\")\\r\\n 3414 | \\r\\n 3415 |             # Limit length and ensure it's not empty\\r\\n 3416 |             slug = slug[:30] if slug else \\\"unknown\\\"\\r\\n 3417 | \\r\\n 3418 |             return slug\\r\\n 3419 | \\r\\n 3420 |         except Exception as e:\\r\\n 3421 |             self.log.warning(f\\\"Failed to generate slug for {category_url}: {e}\\\")\\r\\n 3422 |             return \\\"unknown\\\"\\r\\n 3423 | \\r\\n 3424 |     def _create_normalized_linking_entry(\\r\\n 3425 |         self,\\r\\n 3426 |         product_data: Dict[str, Any],\\r\\n 3427 |         amazon_data: Dict[str, Any],\\r\\n 3428 |         confidence: str = \\\"medium\\\",\\r\\n 3429 |         search_method: str = \\\"unknown\\\",\\r\\n 3430 |     ) -> Dict[str, Any]:\\r\\n 3431 |         \\\"\\\"\\\"Create a normalized linking map entry with consistent EAN and URL normalization.\\\"\\\"\\\"\\r\\n 3432 |         from utils.normalization import normalize_url, stable_key, normalize_ean\\r\\n 3433 | \\r\\n 3434 |         # Extract and normalize EAN\\r\\n 3435 |         supplier_ean = product_data.get(\\\"ean\\\") or product_data.get(\\\"barcode\\\")\\r\\n 3436 |         if supplier_ean == \\\"None\\\" or supplier_ean is None:\\r\\n 3437 |             supplier_ean = None\\r\\n 3438 |         else:\\r\\n 3439 |             supplier_ean = normalize_ean(supplier_ean)\\r\\n 3440 | \\r\\n 3441 |         # Extract and normalize URL\\r\\n 3442 |         supplier_url = product_data.get(\\\"url\\\")\\r\\n 3443 |         if supplier_url:\\r\\n 3444 |             supplier_url = normalize_url(supplier_url)\\r\\n 3445 | \\r\\n 3446 |         # Create normalized linking entry\\r\\n 3447 |         linking_entry = {\\r\\n 3448 |             \\\"supplier_ean\\\": supplier_ean,\\r\\n 3449 |             \\\"supplier_url\\\": supplier_url,\\r\\n 3450 |             \\\"amazon_asin\\\": amazon_data.get(\\\"asin\\\"),\\r\\n 3451 |             \\\"supplier_title\\\": product_data.get(\\\"title\\\"),\\r\\n 3452 |             \\\"amazon_title\\\": amazon_data.get(\\\"title\\\"),\\r\\n 3453 |             \\\"confidence\\\": confidence,\\r\\n 3454 |             \\\"search_method\\\": search_method,\\r\\n 3455 |             \\\"created_at\\\": datetime.utcnow().isoformat() + \\\"Z\\\",\\r\\n 3456 |         }\\r\\n 3457 | \\r\\n 3458 |         return linking_entry\\r\\n 3459 | \\r\\n 3460 |     async def _collect_urls_only(self, category_url: str, max_products: int) -> List[str]:\\r\\n 3461 |         \\\"\\\"\\\"Collect product URLs only without extracting product data\\\"\\\"\\\"\\r\\n 3462 |         try:\\r\\n 3463 |             # Use the scraper's URL collection method without product extraction\\r\\n 3464 |             all_product_urls = await self.supplier_scraper._collect_all_product_urls(\\r\\n 3465 |                 category_url, max_products\\r\\n 3466 |             )\\r\\n 3467 | \\r\\n 3468 |             # Store the discovered count for state manager integration\\r\\n 3469 |             self.supplier_scraper.last_discovered_count = len(all_product_urls)\\r\\n 3470 | \\r\\n 3471 |             return all_product_urls\\r\\n 3472 |         except Exception as e:\\r\\n 3473 |             self.log.error(f\\\"Failed to collect URLs from {category_url}: {e}\\\")\\r\\n 3474 |             return []\\r\\n 3475 | \\r\\n 3476 |     # Removed _scrape_with_retries_filtered method - confirmed broken and leads to extraction failures\\r\\n 3477 |     # Use _scrape_with_retries instead for successful product extraction per project memory\\r\\n 3478 | \\r\\n 3479 |     # LEGACY METHOD REMOVED - _load_cached_products_for_urls\\r\\n 3480 |     # This was part of the 2nd processing phase that loaded cached products incorrectly\\r\\n 3481 |     # Pre-extraction filtering already identifies which products need processing\\r\\n 3482 | \\r\\n 3483 |     async def _scrape_with_retries(\\r\\n 3484 |         self, url: str, max_products_per_category: int, product_accumulator: List[Dict[str, Any]]\\r\\n 3485 |     ):\\r\\n 3486 |         \\\"\\\"\\\"Wrapper around supplier scraper with exponential backoff retries.\\\"\\\"\\\"\\r\\n 3487 |         from tenacity import retry, stop_after_attempt, wait_exponential, before_sleep_log\\r\\n 3488 |         import logging\\r\\n 3489 | \\r\\n 3490 |         @retry(\\r\\n 3491 |             stop=stop_after_attempt(3),\\r\\n 3492 |             wait=wait_exponential(multiplier=1, min=2, max=10),\\r\\n 3493 |             before_sleep=before_sleep_log(self.log, logging.WARNING),\\r\\n 3494 |         )\\r\\n 3495 |         async def _inner():\\r\\n 3496 |             return await self.supplier_scraper.scrape_products_from_url(\\r\\n 3497 |                 url, max_products_per_category, product_accumulator=product_accumulator\\r\\n 3498 |             )\\r\\n 3499 | \\r\\n 3500 |         return await _inner()\\r\\n 3501 | \\r\\n 3502 |     # ──────────────────────── ③  Enhanced State tracking helpers ──────────────────────\\r\\n 3503 |     def _load_history(self):\\r\\n 3504 |         \\\"\\\"\\\"Load comprehensive scraping history to prevent duplicate processing\\\"\\\"\\\"\\r\\n 3505 |         if self.state_path and Path(self.state_path).exists():  # MODIFIED HERE\\r\\n 3506 |             try:\\r\\n 3507 |                 history = json.loads(Path(self.state_path).read_text())  # AND HERE for consistency\\r\\n 3508 |                 # Ensure all required keys exist with backward compatibility\\r\\n 3509 |                 default_history = {\\r\\n 3510 |                     \\\"categories_scraped\\\": [],\\r\\n 3511 |                     \\\"products_processed\\\": [],\\r\\n 3512 |                     \\\"pages_visited\\\": [],\\r\\n 3513 |                     \\\"subpages_scraped\\\": [],\\r\\n 3514 |                     \\\"ai_suggested_categories\\\": [],\\r\\n 3515 |                     \\\"failed_categories\\\": [],\\r\\n 3516 |                     \\\"last_scrape_timestamp\\\": None,\\r\\n 3517 |                     \\\"scrape_sessions\\\": [],\\r\\n 3518 |                     \\\"category_performance\\\": {},\\r\\n 3519 |                     \\\"url_hash_cache\\\": {},\\r\\n 3520 |                     \\\"ai_decision_history\\\": [],  # New field for AI decisions\\r\\n 3521 |                 }\\r\\n 3522 |                 # Merge with defaults to handle missing keys\\r\\n 3523 |                 for key, default_value in default_history.items():\\r\\n 3524 |                     if key not in history:\\r\\n 3525 |                         history[key] = default_value\\r\\n 3526 |                 return history\\r\\n 3527 |             except (json.JSONDecodeError, Exception) as e:\\r\\n 3528 |                 log.warning(f\\\"Failed to load history, creating new: {e}\\\")\\r\\n 3529 |                 return self._get_default_history()\\r\\n 3530 |         return self._get_default_history()\\r\\n 3531 | \\r\\n 3532 |     def _load_ai_memory(self, supplier_name: str) -> Dict[str, Any]:\\r\\n 3533 |         \\\"\\\"\\\"\\r\\n 3534 |         🧠 Load AI memory from AI cache file to prevent re-suggesting same categories.\\r\\n 3535 | \\r\\n 3536 |         Args:\\r\\n 3537 |             supplier_name: Name of the supplier\\r\\n 3538 | \\r\\n 3539 |         Returns:\\r\\n 3540 |             Dictionary containing AI memory data\\r\\n 3541 |         \\\"\\\"\\\"\\r\\n 3542 |         try:\\r\\n 3543 |             ai_cache_file = os.path.join(\\r\\n 3544 |                 AI_CATEGORY_CACHE_DIR, f\\\"{supplier_name.replace('.', '_')}_ai_category_cache.json\\\"\\r\\n 3545 |             )\\r\\n 3546 | \\r\\n 3547 |             if os.path.exists(ai_cache_file):\\r\\n 3548 |                 with open(ai_cache_file, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\r\\n 3549 |                     content = f.read().strip()\\r\\n 3550 |                     if not content or content == \\\"{}\\\":  # File is empty or just empty JSON\\r\\n 3551 |                         log.info(f\\\"🧠 AI cache file is empty for {supplier_name} - starting fresh\\\")\\r\\n 3552 |                         # Don't raise error - return empty memory but let the system continue\\r\\n 3553 |                         return {\\r\\n 3554 |                             \\\"previously_suggested_urls\\\": [],\\r\\n 3555 |                             \\\"total_products_processed\\\": 0,\\r\\n 3556 |                             \\\"ai_history\\\": [],\\r\\n 3557 |                             \\\"total_ai_calls\\\": 0,\\r\\n 3558 |                             \\\"price_phase\\\": \\\"low\\\",\\r\\n 3559 |                         }\\r\\n 3560 |                     ai_cache_data = json.loads(content)\\r\\n 3561 | \\r\\n 3562 |                 # Extract all previously suggested URLs from AI history\\r\\n 3563 |                 previously_suggested_urls = set()\\r\\n 3564 |                 total_products_processed = 0\\r\\n 3565 | \\r\\n 3566 |                 ai_history = ai_cache_data.get(\\\"ai_suggestion_history\\\", [])\\r\\n 3567 |                 for entry in ai_history:\\r\\n 3568 |                     ai_suggestions = entry.get(\\\"ai_suggestions\\\", {})\\r\\n 3569 | \\r\\n 3570 |                     # Collect all suggested URLs\\r\\n 3571 |                     top_urls = ai_suggestions.get(\\\"top_3_urls\\\", [])\\r\\n 3572 |                     secondary_urls = ai_suggestions.get(\\\"secondary_urls\\\", [])\\r\\n 3573 | \\r\\n 3574 |                     previously_suggested_urls.update(top_urls)\\r\\n 3575 |                     previously_suggested_urls.update(secondary_urls)\\r\\n 3576 | \\r\\n 3577 |                     # Track products processed\\r\\n 3578 |                     session_context = entry.get(\\\"session_context\\\", {})\\r\\n 3579 |                     total_products_processed += session_context.get(\\\"total_products_processed\\\", 0)\\r\\n 3580 | \\r\\n 3581 |                 log.info(\\r\\n 3582 |                     f\\\"🧠 AI Memory loaded: {len(previously_suggested_urls)} previously suggested URLs, {total_products_processed} products processed\\\"\\r\\n 3583 |                 )\\r\\n 3584 |                 log.debug(f\\\"🧠 Previously suggested URLs: {list(previously_suggested_urls)}\\\")\\r\\n 3585 | \\r\\n 3586 |                 return {\\r\\n 3587 |                     \\\"previously_suggested_urls\\\": list(previously_suggested_urls),\\r\\n 3588 |                     \\\"total_products_processed\\\": total_products_processed,\\r\\n 3589 |                     \\\"ai_history\\\": ai_history,\\r\\n 3590 |                     \\\"total_ai_calls\\\": ai_cache_data.get(\\\"total_ai_calls\\\", 0),\\r\\n 3591 |                     \\\"price_phase\\\": ai_cache_data.get(\\\"price_phase\\\", \\\"low\\\"),  # Default to Phase 1\\r\\n 3592 |                 }\\r\\n 3593 |             else:\\r\\n 3594 |                 log.info(f\\\"🧠 No AI cache file found for {supplier_name} - starting fresh\\\")\\r\\n 3595 | \\r\\n 3596 |         except Exception as e:\\r\\n 3597 |             log.error(f\\\"Error loading AI memory for {supplier_name}: {e}\\\")\\r\\n 3598 | \\r\\n 3599 |         # Return default empty memory\\r\\n 3600 |         return {\\r\\n 3601 |             \\\"previously_suggested_urls\\\": [],\\r\\n 3602 |             \\\"total_products_processed\\\": 0,\\r\\n 3603 |             \\\"ai_history\\\": [],\\r\\n 3604 |             \\\"total_ai_calls\\\": 0,\\r\\n 3605 |             \\\"price_phase\\\": \\\"low\\\",  # Default to Phase 1\\r\\n 3606 |         }\\r\\n 3607 | \\r\\n 3608 |     def _get_default_history(self):\\r\\n 3609 |         \\\"\\\"\\\"Get default history structure\\\"\\\"\\\"\\r\\n 3610 |         return {\\r\\n 3611 |             \\\"categories_scraped\\\": [],\\r\\n 3612 |             \\\"products_processed\\\": [],\\r\\n 3613 |             \\\"pages_visited\\\": [],\\r\\n 3614 |             \\\"subpages_scraped\\\": [],\\r\\n 3615 |             \\\"ai_suggested_categories\\\": [],\\r\\n 3616 |             \\\"failed_categories\\\": [],\\r\\n 3617 |             \\\"last_scrape_timestamp\\\": None,\\r\\n 3618 |             \\\"scrape_sessions\\\": [],\\r\\n 3619 |             \\\"category_performance\\\": {},\\r\\n 3620 |             \\\"url_hash_cache\\\": {},\\r\\n 3621 |             \\\"ai_decision_history\\\": [],  # New field for AI decisions\\r\\n 3622 |         }\\r\\n 3623 | \\r\\n 3624 |     def _config_manifest_hash(self) -> str:\\r\\n 3625 |         \\\"\\\"\\\"Get configuration manifest hash for lineage tracking.\\\"\\\"\\\"\\r\\n 3626 |         # Return cached hash if available\\r\\n 3627 |         if hasattr(self, '_cached_config_hash'):\\r\\n 3628 |             return self._cached_config_hash\\r\\n 3629 |         \\r\\n 3630 |         # Fallback: compute fresh hash if needed\\r\\n 3631 |         try:\\r\\n 3632 |             category_urls = self._get_predefined_categories(self.supplier_name) or []\\r\\n 3633 |             return self.state_manager.compute_supplier_config_hash(category_urls)\\r\\n 3634 |         except Exception as e:\\r\\n 3635 |             self.log.warning(f\\\"Could not compute config hash: {e}\\\")\\r\\n 3636 |             return \\\"unknown\\\"\\r\\n 3637 | \\r\\n 3638 |     def _get_predefined_categories(self, supplier_name: str) -> list:\\r\\n 3639 |         \\\"\\\"\\\"Load predefined category URLs from a custom JSON file.\\\"\\\"\\\"\\r\\n 3640 |         log.info(f\\\"Attempting to load predefined categories for {supplier_name}\\\")\\r\\n 3641 |         try:\\r\\n 3642 |             # Robust path construction using pathlib\\r\\n 3643 |             config_path = (\\r\\n 3644 |                 Path(__file__).parent.parent\\r\\n 3645 |                 / \\\"config\\\"\\r\\n 3646 |                 / f\\\"{supplier_name.replace('.co.uk', '')}_categories.json\\\"\\r\\n 3647 |             )\\r\\n 3648 | \\r\\n 3649 |             if config_path.exists():\\r\\n 3650 |                 with open(config_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\r\\n 3651 |                     data = json.load(f)\\r\\n 3652 |                     category_urls = data.get(\\\"category_urls\\\", [])\\r\\n 3653 |                     log.info(\\r\\n 3654 |                         f\\\"✅ Successfully loaded {len(category_urls)} predefined category URLs from {config_path}\\\"\\r\\n 3655 |                     )\\r\\n 3656 |                     return category_urls\\r\\n 3657 |             else:\\r\\n 3658 |                 log.warning(f\\\"⚠️ Predefined category file not found at {config_path}\\\")\\r\\n 3659 |                 return []\\r\\n 3660 |         except FileNotFoundError:\\r\\n 3661 |             log.error(f\\\"❌ Configuration file not found: {config_path}\\\")\\r\\n 3662 |             return []\\r\\n 3663 |         except json.JSONDecodeError as e:\\r\\n 3664 |             log.error(f\\\"❌ Invalid JSON in configuration file: {e}\\\")\\r\\n 3665 |             return []\\r\\n 3666 |         except Exception as e:\\r\\n 3667 |             log.error(f\\\"❌ Unexpected error loading predefined categories: {e}\\\")\\r\\n 3668 |             return []\\r\\n 3669 | \\r\\n 3670 |     def _save_history(self, hist: dict):\\r\\n 3671 |         \\\"\\\"\\\"Save comprehensive scraping history with atomic write\\\"\\\"\\\"\\r\\n 3672 |         if self.state_path:\\r\\n 3673 |             # Add current timestamp\\r\\n 3674 |             hist[\\\"last_scrape_timestamp\\\"] = datetime.now().isoformat()\\r\\n 3675 | \\r\\n 3676 |             # Use atomic write to prevent corruption\\r\\n 3677 |             # Ensure self.state_path is a Path object for .with_suffix and os.replace\\r\\n 3678 |             state_path_obj = Path(self.state_path)\\r\\n 3679 |             temp_path = state_path_obj.with_suffix(\\\".tmp\\\")\\r\\n 3680 |             try:\\r\\n 3681 |                 with open(temp_path, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\r\\n 3682 |                     json.dump(hist, f, indent=2, ensure_ascii=False)\\r\\n 3683 |                 os.replace(temp_path, state_path_obj)  # Use Path object here too\\r\\n 3684 |                 log.debug(\\r\\n 3685 |                     f\\\"History saved with {len(hist.get('categories_scraped', []))} categories, {len(hist.get('pages_visited', []))} pages\\\"\\r\\n 3686 |                 )\\r\\n 3687 |             except Exception as e:\\r\\n 3688 |                 log.error(f\\\"Failed to save history: {e}\\\")\\r\\n 3689 |                 if os.path.exists(temp_path):  # os.path.exists is fine for string or Path\\r\\n 3690 |                     try:\\r\\n 3691 |                         os.remove(temp_path)\\r\\n 3692 |                     except:\\r\\n 3693 |                         pass\\r\\n 3694 | \\r\\n 3695 |     def _record_ai_decision(self, hist: dict, ai_response: dict):\\r\\n 3696 |         \\\"\\\"\\\"Record AI decision for future reference and learning\\\"\\\"\\\"\\r\\n 3697 |         hist.setdefault(\\\"ai_decision_history\\\", []).append(\\r\\n 3698 |             {\\r\\n 3699 |                 \\\"timestamp\\\": datetime.utcnow().isoformat(timespec=\\\"seconds\\\"),\\r\\n 3700 |                 \\\"categories_suggested\\\": ai_response[\\\"top_3_urls\\\"],\\r\\n 3701 |                 \\\"skip_urls\\\": ai_response[\\\"skip_urls\\\"],\\r\\n 3702 |                 \\\"reasoning\\\": ai_response.get(\\\"detailed_reasoning\\\", {}),\\r\\n 3703 |                 \\\"progression_strategy\\\": ai_response.get(\\\"progression_strategy\\\", \\\"unknown\\\"),\\r\\n 3704 |             }\\r\\n 3705 |         )\\r\\n 3706 |         # DEPRECATED: Replaced by EnhancedStateManager to prevent state conflicts\\r\\n 3707 |         # self._save_history(hist)\\r\\n 3708 | \\r\\n 3709 |     def _is_url_previously_scraped(self, url: str, hist: dict) -> bool:\\r\\n 3710 |         \\\"\\\"\\\"Check if URL has been previously scraped using multiple tracking methods\\\"\\\"\\\"\\r\\n 3711 |         if not url:\\r\\n 3712 |             return False\\r\\n 3713 | \\r\\n 3714 |         # Direct URL check\\r\\n 3715 |         if url in hist.get(\\\"categories_scraped\\\", []):\\r\\n 3716 |             return True\\r\\n 3717 |         if url in hist.get(\\\"pages_visited\\\", []):\\r\\n 3718 |             return True\\r\\n 3719 |         if url in hist.get(\\\"subpages_scraped\\\", []):\\r\\n 3720 |             return True\\r\\n 3721 | \\r\\n 3722 |         # URL hash check for similar URLs (handles pagination, query params)\\r\\n 3723 |         import hashlib\\r\\n 3724 | \\r\\n 3725 |         url_hash = hashlib.md5(url.encode()).hexdigest()\\r\\n 3726 |         if url_hash in hist.get(\\\"url_hash_cache\\\", {}):\\r\\n 3727 |             cached_url = hist[\\\"url_hash_cache\\\"][url_hash]\\r\\n 3728 |             log.debug(f\\\"URL hash match found: {url} matches previously scraped {cached_url}\\\")\\r\\n 3729 |             return True\\r\\n 3730 | \\r\\n 3731 |         # Normalize URL and check (remove trailing slashes, query params for base comparison)\\r\\n 3732 |         from urllib.parse import urlparse, parse_qs\\r\\n 3733 | \\r\\n 3734 |         parsed = urlparse(url)\\r\\n 3735 |         base_url = f\\\"{parsed.scheme}://{parsed.netloc}{parsed.path.rstrip('/')}\\\"\\r\\n 3736 | \\r\\n 3737 |         for scraped_url in hist.get(\\\"categories_scraped\\\", []) + hist.get(\\\"pages_visited\\\", []):\\r\\n 3738 |             scraped_parsed = urlparse(scraped_url)\\r\\n 3739 |             scraped_base = f\\\"{scraped_parsed.scheme}://{scraped_parsed.netloc}{scraped_parsed.path.rstrip('/')}\\\"\\r\\n 3740 |             if base_url == scraped_base:\\r\\n 3741 |                 log.debug(f\\\"Base URL match: {url} matches {scraped_url}\\\")\\r\\n 3742 |                 return True\\r\\n 3743 | \\r\\n 3744 |         return False\\r\\n 3745 | \\r\\n 3746 |     def _add_url_to_history(self, url: str, hist: dict, url_type: str = \\\"page\\\"):\\r\\n 3747 |         \\\"\\\"\\\"Add URL to appropriate history list and hash cache\\\"\\\"\\\"\\r\\n 3748 |         if not url:\\r\\n 3749 |             return\\r\\n 3750 | \\r\\n 3751 |         # Add to appropriate list\\r\\n 3752 |         if url_type == \\\"category\\\":\\r\\n 3753 |             if url not in hist.get(\\\"categories_scraped\\\", []):\\r\\n 3754 |                 hist.setdefault(\\\"categories_scraped\\\", []).append(url)\\r\\n 3755 |         elif url_type == \\\"subpage\\\":\\r\\n 3756 |             if url not in hist.get(\\\"subpages_scraped\\\", []):\\r\\n 3757 |                 hist.setdefault(\\\"subpages_scraped\\\", []).append(url)\\r\\n 3758 |         else:  # default to pages_visited\\r\\n 3759 |             if url not in hist.get(\\\"pages_visited\\\", []):\\r\\n 3760 |                 hist.setdefault(\\\"pages_visited\\\", []).append(url)\\r\\n 3761 | \\r\\n 3762 |         # Add to hash cache\\r\\n 3763 |         import hashlib\\r\\n 3764 | \\r\\n 3765 |         url_hash = hashlib.md5(url.encode()).hexdigest()\\r\\n 3766 |         hist.setdefault(\\\"url_hash_cache\\\", {})[url_hash] = url\\r\\n 3767 | \\r\\n 3768 |         log.debug(f\\\"Added {url_type} URL to history: {url}\\\")\\r\\n 3769 | \\r\\n 3770 |     def _record_category_performance(self, category_url: str, products_found: int, hist: dict):\\r\\n 3771 |         \\\"\\\"\\\"Record performance metrics for categories to improve future AI suggestions\\\"\\\"\\\"\\r\\n 3772 |         hist.setdefault(\\\"category_performance\\\", {})[category_url] = {\\r\\n 3773 |             \\\"products_found\\\": products_found,\\r\\n 3774 |             \\\"last_scraped\\\": datetime.now().isoformat(),\\r\\n 3775 |             \\\"performance_score\\\": min(products_found / 10.0, 1.0),  # Normalize to 0-1 scale\\r\\n 3776 |         }\\r\\n 3777 | \\r\\n 3778 |     def _get_category_performance_summary(self, hist: dict) -> str:\\r\\n 3779 |         \\\"\\\"\\\"Get summary of category performance for AI context\\\"\\\"\\\"\\r\\n 3780 |         performance = hist.get(\\\"category_performance\\\", {})\\r\\n 3781 |         if not performance:\\r\\n 3782 |             return \\\"No previous category performance data available.\\\"\\r\\n 3783 | \\r\\n 3784 |         summary_lines = [\\\"Previous category performance:\\\"]\\r\\n 3785 |         sorted_categories = sorted(\\r\\n 3786 |             performance.items(), key=lambda x: x[1][\\\"performance_score\\\"], reverse=True\\r\\n 3787 |         )\\r\\n 3788 | \\r\\n 3789 |         for url, metrics in sorted_categories[:5]:  # Top 5 performing categories\\r\\n 3790 |             summary_lines.append(\\r\\n 3791 |                 f\\\"- {url}: {metrics['products_found']} products (score: {metrics['performance_score']:.2f})\\\"\\r\\n 3792 |             )\\r\\n 3793 | \\r\\n 3794 |         if len(sorted_categories) > 5:\\r\\n 3795 |             summary_lines.append(f\\\"... and {len(sorted_categories) - 5} more categories\\\")\\r\\n 3796 | \\r\\n 3797 |         return \\\"\\\\n\\\".join(summary_lines)\\r\\n 3798 | \\r\\n 3799 |     # ──────────────────────── PHASE 3: SUBCATEGORY DEDUPLICATION ──────────────────────────\\r\\n 3800 |     def _detect_parent_child_urls(self, urls: List[str]) -> Dict[str, List[str]]:\\r\\n 3801 |         \\\"\\\"\\\"\\r\\n 3802 |         Detect parent-child URL relationships to prevent double processing.\\r\\n 3803 |         Returns dict where keys are parent URLs and values are lists of child URLs.\\r\\n 3804 |
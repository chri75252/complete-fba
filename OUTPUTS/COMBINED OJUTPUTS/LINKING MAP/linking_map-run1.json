r\\n  605 | \\r\\n  606 | # Initial constants and paths\\r\\n  607 | # Get the base directory path dynamically\\r\\n  608 | BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))\\r\\n  609 | OUTPUT_DIR = os.getenv(\\\"OUTPUT_DIR\\\", os.path.join(BASE_DIR, \\\"OUTPUTS\\\", \\\"FBA_ANALYSIS\\\"))\\r\\n  610 | os.makedirs(OUTPUT_DIR, exist_ok=True)\\r\\n  611 | \\r\\n  612 | \\r\\n  613 | # Load cache directories from config/system_config.json\\r\\n  614 | def _load_cache_directories():\\r\\n  615 |     try:\\r\\n  616 |         config_path = os.path.join(\\r\\n  617 |             os.path.dirname(os.path.dirname(os.path.abspath(__file__))),\\r\\n  618 |             \\\"config\\\",\\r\\n  619 |             \\\"system_config.json\\\",\\r\\n  620 |         )\\r\\n  621 |         with open(config_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\r\\n  622 |             config = json.load(f)\\r\\n  623 |         cache_dirs = config.get(\\\"cache\\\", {}).get(\\\"directories\\\", {})\\r\\n  624 |         return cache_dirs\\r\\n  625 |     except Exception as e:\\r\\n  626 |         logging.warning(f\\\"Failed to load cache directories from config: {e}\\\")\\r\\n  627 |         return {}\\r\\n  628 | \\r\\n  629 | \\r\\n  630 | cache_directories = _load_cache_directories()\\r\\n  631 | \\r\\n  632 | # Global constant for persistent linking map in dedicated directory\\r\\n  633 | LINKING_MAP_DIR = os.path.join(OUTPUT_DIR, \\\"linking_maps\\\")\\r\\n  634 | os.makedirs(LINKING_MAP_DIR, exist_ok=True)\\r\\n  635 | LINKING_MAP_PATH = os.path.join(LINKING_MAP_DIR, \\\"linking_map.json\\\")\\r\\n  636 | \\r\\n  637 | # Other directories\\r\\n  638 | SUPPLIER_CACHE_DIR = os.path.join(BASE_DIR, \\\"OUTPUTS\\\", \\\"cached_products\\\")\\r\\n  639 | AMAZON_CACHE_DIR = os.path.join(OUTPUT_DIR, \\\"amazon_cache\\\")\\r\\n  640 | AI_CATEGORY_CACHE_DIR = os.path.join(OUTPUT_DIR, \\\"ai_category_cache\\\")\\r\\n  641 | \\r\\n  642 | os.makedirs(SUPPLIER_CACHE_DIR, exist_ok=True)\\r\\n  643 | os.makedirs(AMAZON_CACHE_DIR, exist_ok=True)\\r\\n  644 | os.makedirs(AI_CATEGORY_CACHE_DIR, exist_ok=True)\\r\\n  645 | \\r\\n  646 | \\r\\n  647 | # Load OpenAI configuration from system config\\r\\n  648 | def _load_openai_config():\\r\\n  649 |     \\\"\\\"\\\"Load OpenAI configuration from system_config.json\\\"\\\"\\\"\\r\\n  650 |     try:\\r\\n  651 |         config_path = os.path.join(\\r\\n  652 |             os.path.dirname(os.path.dirname(os.path.abspath(__file__))),\\r\\n  653 |             \\\"config\\\",\\r\\n  654 |             \\\"system_config.json\\\",\\r\\n  655 |         )\\r\\n  656 |         with open(config_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\r\\n  657 |             config = json.load(f)\\r\\n  658 | \\r\\n  659 |         openai_config = config.get(\\\"integrations\\\", {}).get(\\\"openai\\\", {})\\r\\n  660 |         return {\\r\\n  661 |             \\\"api_key\\\": openai_config.get(\\\"api_key\\\", \\\"\\\"),\\r\\n  662 |             \\\"model\\\": openai_config.get(\\\"model\\\", \\\"gpt-4o-mini\\\"),\\r\\n  663 |             \\\"enabled\\\": openai_config.get(\\\"enabled\\\", False),\\r\\n  664 |         }\\r\\n  665 |     except Exception as e:\\r\\n  666 |         log.warning(f\\\"Failed to load OpenAI config from system_config.json: {e}\\\")\\r\\n  667 |         return {\\r\\n  668 |             \\\"api_key\\\": os.getenv(\\\"OPENAI_API_KEY\\\", \\\"\\\"),\\r\\n  669 |             \\\"model\\\": os.getenv(\\\"OPENAI_MODEL\\\", \\\"gpt-4o-mini\\\"),\\r\\n  670 |             \\\"enabled\\\": True,\\r\\n  671 |         }\\r\\n  672 | \\r\\n  673 | \\r\\n  674 | # Load OpenAI configuration\\r\\n  675 | _openai_config = _load_openai_config()\\r\\n  676 | \\r\\n  677 | # Load API key and model from environment variables or config\\r\\n  678 | OPENAI_API_KEY = os.getenv(\\\"OPENAI_API_KEY\\\") or _openai_config.get(\\\"api_key\\\", \\\"\\\")\\r\\n  679 | OPENAI_MODEL_NAME = os.getenv(\\\"OPENAI_MODEL_PRIMARY\\\", \\\"gpt-4o-mini-2024-07-18\\\")\\r\\n  680 | OPENAI_ENABLED = bool(OPENAI_API_KEY) and _openai_config.get(\\\"enabled\\\", True)\\r\\n  681 | \\r\\n  682 | if not OPENAI_API_KEY:\\r\\n  683 |     log.error(\\\"🚨 OPENAI_API_KEY not found in environment variables or config!\\\")\\r\\n  684 |     log.error(\\\"Please set OPENAI_API_KEY environment variable or update config/system_config.json\\\")\\r\\n  685 |     sys.exit(1)\\r\\n  686 | # REMOVED: SUPPLIER_CONFIGS dictionary, as this is now handled by ConfigurableSupplierScraper and supplier_config_loader.py\\r\\n  687 | \\r\\n  688 | # Battery product detection constants\\r\\n  689 | BATTERY_KEYWORDS = (\\\"battery\\\", \\\"batteries\\\", \\\"cell\\\", \\\"cr20\\\", \\\"lr41\\\", \\\"lithium\\\", \\\"alkaline\\\")\\r\\n  690 | \\r\\n  691 | \\r\\n  692 | def is_battery_title(title: str) -> bool:\\r\\n  693 |     \\\"\\\"\\\"Check if a product title indicates it's a battery product.\\\"\\\"\\\"\\r\\n  694 |     if not title:\\r\\n  695 |         return False\\r\\n  696 |     return any(k in title.lower() for k in BATTERY_KEYWORDS)\\r\\n  697 | \\r\\n  698 | \\r\\n  699 | class FixedAmazonExtractor(AmazonExtractor):\\r\\n  700 |     \\\"\\\"\\\"\\r\\n  701 |     Extension of AmazonExtractor.\\r\\n  702 |     Includes EAN search capabilities and attempts EAN extraction from product pages.\\r\\n  703 |     It reuses browser pages and avoids unnecessary page creation/closure for extension stability.\\r\\n  704 |     \\\"\\\"\\\"\\r\\n  705 | \\r\\n  706 |     def __init__(self, chrome_debug_port: int, ai_client: Optional[OpenAI] = None):\\r\\n  707 |         super().__init__(chrome_debug_port, ai_client)\\r\\n  708 |         # self.ai_client is already set by parent constructor if ai_client is passed.\\r\\n  709 | \\r\\n  710 |     async def connect(self) -> Browser:  # type: ignore\\r\\n  711 |         \\\"\\\"\\\"\\r\\n  712 |         Connect to browser using the centralized BrowserManager singleton.\\r\\n  713 |         All browser operations now go through the shared BrowserManager instance.\\r\\n  714 |         \\\"\\\"\\\"\\r\\n  715 |         log.info(f\\\"🔧 FixedAmazonExtractor connecting via BrowserManager singleton\\\")\\r\\n  716 |         try:\\r\\n  717 |             # Use the browser manager singleton for centralized browser management\\r\\n  718 |             browser_manager = BrowserManager.get_instance()\\r\\n  719 | \\r\\n  720 |             # Ensure browser manager is properly launched\\r\\n  721 |             if not hasattr(browser_manager, \\\"browser\\\") or not browser_manager.browser:\\r\\n  722 |                 await browser_manager.launch_browser(cdp_port=self.chrome_debug_port)\\r\\n  723 | \\r\\n  724 |             # Get the shared browser instance\\r\\n  725 |             self.browser = browser_manager.browser\\r\\n  726 |             log.info(\\\"✅ FixedAmazonExtractor connected via BrowserManager singleton\\\")\\r\\n  727 | \\r\\n  728 |             return self.browser\\r\\n  729 |         except Exception as e:\\r\\n  730 |             log.error(f\\\"❌ FixedAmazonExtractor failed to connect via BrowserManager: {e}\\\")\\r\\n  731 |             log.error(\\r\\n  732 |                 \\\"Ensure Chrome is running with --remote-debugging-port=9222 and BrowserManager is properly initialized\\\"\\r\\n  733 |             )\\r\\n  734 |             raise\\r\\n  735 | \\r\\n  736 |     def _overlap_score(self, title_a: str, title_b: str) -> float:\\r\\n  737 |         \\\"\\\"\\\"Calculate word overlap score between two titles\\\"\\\"\\\"\\r\\n  738 |         a = set(re.sub(r\\\"[^\\\\w\\\\s]\\\", \\\" \\\", title_a.lower()).split())\\r\\n  739 |         b = set(re.sub(r\\\"[^\\\\w\\\\s]\\\", \\\" \\\", title_b.lower()).split())\\r\\n  740 |         return len(a & b) / max(1, len(a))\\r\\n  741 | \\r\\n  742 |     async def search_by_title_using_search_bar(\\r\\n  743 |         self, title: str, page: Optional[Page] = None\\r\\n  744 |     ) -> Dict[str, Any]:\\r\\n  745 |         \\\"\\\"\\\"Search Amazon by title using search bar interaction (not URL building)\\\"\\\"\\\"\\r\\n  746 |         if not self.browser or not self.browser.is_connected():\\r\\n  747 |             await self.connect()\\r\\n  748 | \\r\\n  749 |         log.info(f\\\"Searching Amazon by title using search bar: '{title}'\\\")\\r\\n  750 | \\r\\n  751 |         # Get page from parameter or use BrowserManager\\r\\n  752 |         if page is None:\\r\\n  753 |             from utils.browser_manager import get_page_for_url\\r\\n  754 | \\r\\n  755 |             log.info(\\\"No page provided to search_by_title, getting one from BrowserManager.\\\")\\r\\n  756 |             page = await get_page_for_url(\\\"https://www.amazon.co.uk\\\", reuse_existing=True)\\r\\n  757 | \\r\\n  758 |         try:\\r\\n  759 |             # Navigate to Amazon UK and search by typing title into search bar\\r\\n  760 |             log.info(f\\\"Navigating to Amazon UK to search for title: {title}\\\")\\r\\n  761 |             await page.goto(\\\"https://www.amazon.co.uk\\\", timeout=60000)\\r\\n  762 | \\r\\n  763 |             # Type title into search box and press Enter\\r\\n  764 |             await page.fill(\\\"input#twotabsearchtextbox\\\", title, timeout=5000)\\r\\n  765 |             await page.press(\\\"input#twotabsearchtextbox\\\", \\\"Enter\\\")\\r\\n  766 | \\r\\n  767 |             # Wait for search results\\r\\n  768 |             await page.wait_for_selector(\\\"div.s-search-results\\\", timeout=15000)\\r\\n  769 | \\r\\n  770 |             # Parse search results - extract first few results with improved element selection\\r\\n  771 |             potential_asins_info = []\\r\\n  772 | \\r\\n  773 |             # Try multiple selectors for search result elements\\r\\n  774 |             search_result_elements = []\\r\\n  775 |             search_selectors = [\\r\\n  776 |                 \\\"div.s-search-results > div[data-asin]\\\",\\r\\n  777 |                 \\\"div[data-component-type='s-search-result']\\\",\\r\\n  778 |                 \\\"div[data-asin]:not([data-asin=''])\\\",\\r\\n  779 |                 \\\"[cel_widget_id*='MAIN-SEARCH_RESULTS'] div[data-asin]\\\",\\r\\n  780 |             ]\\r\\n  781 | \\r\\n  782 |             for selector in search_selectors:\\r\\n  783 |                 try:\\r\\n  784 |                     elements = await page.query_selector_all(selector)\\r\\n  785 |                     if elements:\\r\\n  786 |                         search_result_elements = elements\\r\\n  787 |                         log.info(\\r\\n  788 |                             f\\\"Title search found {len(elements)} elements using selector: {selector}\\\"\\r\\n  789 |                         )\\r\\n  790 |                         break\\r\\n  791 |                 except Exception as e:\\r\\n  792 |                     log.debug(f\\\"Title search selector '{selector}' failed: {e}\\\")\\r\\n  793 |                     continue\\r\\n  794 | \\r\\n  795 |             for element in search_result_elements[:10]:  # More results for title search\\r\\n  796 |                 asin = await element.get_attribute(\\\"data-asin\\\")\\r\\n  797 |                 # FIX: Remove overly restrictive 10-character requirement for ASIN validation\\r\\n  798 |                 # ASINs can be valid with fewer than 10 characters\\r\\n  799 |                 if (\\r\\n  800 |                     asin and len(asin) >= 8 and len(asin) <= 12\\r\\n  801 |                 ):  # More reasonable range for ASIN validation\\r\\n  802 |                     # Use improved title extraction\\r\\n  803 |                     result_title = await self._extract_title_from_element(element, asin)\\r\\n  804 | \\r\\n  805 |                     potential_asins_info.append({\\\"asin\\\": asin, \\\"title\\\": result_title})\\r\\n  806 | \\r\\n  807 |             # Create search_results_data in expected format\\r\\n  808 |             if potential_